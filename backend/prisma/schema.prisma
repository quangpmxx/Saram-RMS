// Prisma schema — Phase 0 + Phase 1 + Phase 2 + Phase 3 + Phase 4 + Phase 5 (docs/14-roadmap.md)
//
// Phase 0: teams, accounts, sessions, audit_logs
// Phase 1: lead_sources, status_catalog, leads, import_jobs
// Phase 2: kích hoạt logic đọc/ghi cho các cột assigned_to/assigned_team_id/
// assigned_at/assignment_method (đã tồn tại rỗng từ Phase 1) + 2 index phục
// vụ truy vấn "Lead của tôi" (Sale) và lọc theo nhóm (Leader/Quản lý/Admin),
// đúng theo đề xuất index tại Mục 6, tài liệu 11.
// Phase 3: bảng mới `lead_notes` (Mục 2.9, tài liệu 11) + kích hoạt logic
// đọc/ghi cho leads.call_status_id/call_result_id/last_activity_at (đã tồn
// tại rỗng từ Phase 1) — Pipeline cuộc gọi & Lịch sử ghi chú.
// Phase 4: bảng mới `interview_appointments`, `callback_schedules` (Mục
// 2.10-2.11, tài liệu 11) + kích hoạt logic đọc/ghi cho
// leads.current_interview_status_id/current_employment_status_id/
// current_partner_company_name (đã tồn tại rỗng từ Phase 1, đồng bộ lại mỗi
// khi có dòng interview_appointments mới/cập nhật, đúng lý do denormalize
// đã ghi tại Mục 7.2, tài liệu 11).
// Phase 5: bảng mới `system_configs` (Mục 2.15, tài liệu 11) + kích hoạt
// logic đọc/ghi cho leads.is_held/held_by/held_at/entered_care_pool_at/
// care_pool_locked_by/care_pool_locked_at/removed_from_care_pool_by/
// removed_from_care_pool_at (đã tồn tại rỗng từ Phase 1) + 2 composite index
// phục vụ truy vấn Cột chăm sóc theo nhóm và worker quét định kỳ, đúng theo
// đề xuất index tại Mục 6, tài liệu 11 — Cột chăm sóc tự động (Care Pool).
// Phase 6: bảng mới `auto_distribution_rules`, `auto_distribution_members`
// (Mục 2.12-2.13, tài liệu 11) — Tự động phân chia lead (Round-robin). Cột
// leads.assignment_method đã có sẵn giá trị enum "auto" từ Phase 1 (chưa
// dùng tới), Phase 6 là nơi đầu tiên thực sự ghi giá trị này.
// Phase 8: bảng mới `notifications` (Mục 2.14, tài liệu 11) — hàng đợi
// thông báo nhắc lịch qua Zalo (Thông báo Zalo).
// Phase 9: bảng mới `permissions`, `account_permissions` (Mục 2.4-2.5, tài
// liệu 11) — khung Phân quyền chi tiết. Theo đúng cảnh báo tường minh của
// docs/14-roadmap.md (Phase 9): danh sách quyền cụ thể CHƯA được chốt với
// chủ doanh nghiệp thật (Mục 11.1, tài liệu 09) — bảng `permissions` được
// seed 5 quyền tạm (xem seedPhase9Permissions() trong seed.ts) do người
// dùng trực tiếp duyệt trong phiên làm việc, không phải danh sách chính
// thức cuối cùng, có thể điều chỉnh sau.
//
// Cấu trúc cột bám sát tuyệt đối docs/11-database-design.md (Design Freeze).
// Bảng `leads` được tạo với ĐẦY ĐỦ cột theo tài liệu 11 Mục 2.8 ngay từ Phase 1
// — không phải "code trước" các Phase sau, mà vì đối tượng "Candidate" trong
// docs/13 Mục 0.1 (API đã chốt) đã cam kết trả về đầy đủ các trường này trong
// mọi response GET /candidate. Các cột thuộc nghiệp vụ Phase 2+ (assigned_at,
// call_status_id, is_held, care_pool_*...) chỉ tồn tại như cột rỗng — KHÔNG có
// bất kỳ API/logic nào của Phase 1 ghi hay đọc có ý nghĩa vào các cột đó; toàn
// bộ hành vi liên quan sẽ do đúng Phase tương ứng bổ sung sau, không migration
// lại bảng `leads` nữa. `status_catalog` được tạo kèm để đáp ứng ràng buộc
// khóa ngoại của các cột đó (Mục 2.7, tài liệu 11) — bảng khác (leads_notes,
// interview_appointments, callback_schedules, permissions, notifications...)
// KHÔNG được tạo vì không thuộc đối tượng Candidate và thuộc hẳn Phase sau.
// `import_jobs` là bảng tự bổ sung (giống cách Phase 0 đã làm với `sessions`)
// — cần thiết để hiện thực đúng API đã chốt `GET /candidate/import/:jobId`
// (Mục 4, tài liệu 13) vì tài liệu 11 không có bảng nào phục vụ việc này.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Khớp cột "role" của bảng accounts (Mục 2.2, tài liệu 11)
enum AccountRole {
  admin
  manager
  leader
  mkt
  sale

  @@map("account_role")
}

// Khớp cột "status" của bảng accounts (Mục 2.2, tài liệu 11)
enum AccountStatus {
  active
  inactive

  @@map("account_status")
}

/// Dự án phụ — nâng cấp toàn diện (2026-07-14, ngoài phạm vi Design Freeze
/// docs/09-13 — module hoàn toàn mới, yêu cầu trực tiếp người dùng): 5 trạng
/// thái chấm công/ngày. "Ô trống = chưa chấm" KHÔNG phải 1 giá trị enum — thể
/// hiện bằng việc KHÔNG có bản ghi AttendanceRecord cho (account, date) đó
/// (xem attendance.service.ts) — xóa trạng thái = xóa hẳn bản ghi.
enum AttendanceStatus {
  /// Có công (✓) = 1 công
  present
  /// Nửa công (½) = 0,5 công
  half
  /// Nghỉ phép (NP) = 0 công — chưa có quy tắc phép hưởng lương nào có sẵn
  /// trong hệ thống (đã rà soát docs/09-13 + toàn bộ codebase, không thấy),
  /// nên dùng đúng giá trị dự phòng "0 công" mà yêu cầu người dùng đã nêu.
  paid_leave
  /// Nghỉ không phép (N) = 0 công
  unpaid_leave
  /// Nghỉ lễ (L) = 0 công (tính vào nhóm "các trạng thái nghỉ = 0" theo yêu
  /// cầu người dùng — hệ thống hiện chưa có quy tắc lễ hưởng lương riêng)
  holiday
  /// Nghỉ bù (B) = 0 công, thêm 2026-07-15 (yêu cầu trực tiếp người dùng) —
  /// cùng nhóm "các trạng thái nghỉ = 0" như NP/N/L. KHÔNG trừ vào
  /// remainingLeaveDays (khác NP) — nghỉ bù không phải phép năm, chưa có
  /// yêu cầu liên kết với số dư phép, không tự phát minh thêm liên kết đó.
  compensatory_leave

  @@map("attendance_status")
}

// Khớp cột "action_type" của bảng audit_logs (Mục 2.16, tài liệu 11)
// Đầy đủ toàn bộ giá trị đã liệt kê, kể cả những giá trị chưa dùng ở Phase 0
// (assign/transfer/hold/lock/unlock sẽ dùng ở Phase 2/5) — vì đây là cấu trúc
// bảng đã Design Freeze, không được rút gọn enum theo phạm vi từng Phase.
enum AuditActionType {
  view
  create
  update
  delete
  assign
  transfer
  hold
  lock
  unlock
  login
  logout
  reset_password

  @@map("audit_action_type")
}

/// Mục 2.1, tài liệu 11 — Nhóm/đội sale, gắn với 1 leader
model Team {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  leaderId  String?  @unique @map("leader_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  leader  Account?  @relation("TeamLeader", fields: [leaderId], references: [id])
  members Account[] @relation("TeamMembers")

  // Phase 6 — quan hệ ngược tới cấu hình tự động phân chia
  distributionRule DistributionRule?

  // Dự án phụ — nâng cấp toàn diện: quan hệ ngược từ DailyReport (Báo cáo hằng ngày)
  dailyReports DailyReport[]

  @@map("teams")
}

/// Mục 2.2, tài liệu 11 — Tài khoản nhân viên (Admin/Quản lý/Leader/MKT/Sale)
model Account {
  id           String        @id @default(uuid()) @db.Uuid
  fullName     String        @map("full_name") @db.VarChar(150)
  username     String        @unique @db.VarChar(50)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  role         AccountRole
  teamId       String?       @map("team_id") @db.Uuid
  status       AccountStatus @default(active)
  // Dự án phụ — nâng cấp toàn diện (ngoài phạm vi Design Freeze docs/09-13):
  // ảnh đại diện tự upload, đường dẫn tương đối phục vụ tĩnh qua
  // useStaticAssets() trong main.ts (vd "/uploads/avatars/xxx.jpg").
  avatarUrl    String?       @map("avatar_url") @db.VarChar(500)
  // Dự án phụ — nâng cấp toàn diện (2026-07-15, ngoài phạm vi Design Freeze
  // docs/09-13, yêu cầu trực tiếp người dùng — module Chấm công): "chức vụ"
  // tùy chỉnh, sửa tay được — null = chưa đặt, khi đó cột "Vị trí" ở bảng
  // chấm công hiện nhãn vai trò (role) mặc định như trước (xem
  // attendance.service.ts). Không thay thế `role` (vẫn giữ nguyên nghiệp vụ
  // phân quyền dựa trên role) — chỉ là nhãn hiển thị tùy chỉnh thêm.
  position     String?       @db.VarChar(100)
  // Dự án phụ — nâng cấp toàn diện (2026-07-15, ngoài phạm vi Design Freeze
  // docs/09-13, yêu cầu trực tiếp người dùng): 5 field hồ sơ nhân sự — CHỈ
  // Admin sửa được (qua trang Quản lý tài khoản), Nhân viên/Leader chỉ XEM
  // (trang Cài đặt tài khoản, xem accounts.controller.ts/@Roles('admin') so
  // với auth.controller.ts GET /me không giới hạn vai trò). Đều nullable —
  // tài khoản cũ chưa có dữ liệu.
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  hireDate           DateTime? @map("hire_date") @db.Date
  personalPhone      String?   @map("personal_phone") @db.VarChar(20)
  personalEmail      String?   @map("personal_email") @db.VarChar(255)
  /// Số ngày phép còn lại. Admin đặt số ban đầu (trang Quản lý tài khoản).
  /// Từ 2026-07-15 (yêu cầu trực tiếp người dùng): TỰ ĐỘNG +1 mỗi khi sang
  /// tháng mới (xem leave-accrual.service.ts), và TỰ ĐỘNG trừ 1 khi tick
  /// "NP" (Nghỉ phép) trên bảng chấm công / hoàn lại khi bỏ tick (xem
  /// attendance.service.ts bulkSave()) — không còn là số tay hoàn toàn.
  remainingLeaveDays Float?    @map("remaining_leave_days")
  /// Dấu mốc lần gần nhất được cộng dồn phép tháng — dùng để 1 tài khoản
  /// không bao giờ bị cộng 2 lần trong cùng 1 tháng dù cron chạy lại/server
  /// khởi động lại (so sánh tháng theo giờ Việt Nam, không so đúng giờ
  /// phút). NULL = chưa từng được cộng.
  lastLeaveAccrualAt DateTime? @map("last_leave_accrual_at")
  createdById  String?       @map("created_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  team            Team?      @relation("TeamMembers", fields: [teamId], references: [id])
  leaderOfTeam    Team?      @relation("TeamLeader")
  createdBy       Account?   @relation("AccountCreatedBy", fields: [createdById], references: [id])
  createdAccounts Account[]  @relation("AccountCreatedBy")
  sessions        Session[]
  auditLogs       AuditLog[]

  // Phase 1 — quan hệ ngược từ Lead/ImportJob
  uploadedLeads            Lead[]      @relation("LeadUploadedBy")
  assignedLeads            Lead[]      @relation("LeadAssignedTo")
  heldLeads                Lead[]      @relation("LeadHeldBy")
  carePoolLockedLeads      Lead[]      @relation("LeadCarePoolLockedBy")
  removedFromCarePoolLeads Lead[]      @relation("LeadRemovedFromCarePoolBy")
  deletedLeads             Lead[]      @relation("LeadDeletedBy")
  importJobs               ImportJob[]

  // Phase 3 — quan hệ ngược từ LeadNote
  createdLeadNotes LeadNote[] @relation("LeadNoteCreatedBy")
  deletedLeadNotes LeadNote[] @relation("LeadNoteDeletedBy")

  // Phase 4 — quan hệ ngược từ InterviewAppointment/CallbackSchedule
  createdInterviews InterviewAppointment[] @relation("InterviewAppointmentCreatedBy")
  createdCallbacks  CallbackSchedule[]     @relation("CallbackScheduleCreatedBy")

  // Phase 5 — quan hệ ngược từ SystemConfig
  updatedConfigs SystemConfig[]

  // Dự án phụ — nâng cấp toàn diện: quan hệ ngược từ ColumnWidthConfig
  updatedColumnWidthConfigs ColumnWidthConfig[]

  // Phase 6 — quan hệ ngược từ DistributionRule/DistributionMember
  createdDistributionRules DistributionRule[]
  distributionMemberships  DistributionMember[]

  // Phase 8 — quan hệ ngược từ Notification
  notifications Notification[]
  // Dự án phụ — nâng cấp toàn diện: quan hệ ngược người gửi (admin_message)
  sentNotifications Notification[] @relation("NotificationSender")

  // Phase 9 — quan hệ ngược từ AccountPermission
  permissionGrants        AccountPermission[] @relation("AccountPermissionAccount")
  updatedPermissionGrants AccountPermission[] @relation("AccountPermissionUpdatedBy")

  // Dự án phụ — nâng cấp toàn diện: quan hệ ngược từ ShuttleRecord (Danh sách đưa đón)
  createdShuttleRecords ShuttleRecord[] @relation("ShuttleRecordCreatedBy")
  updatedShuttleRecords ShuttleRecord[] @relation("ShuttleRecordUpdatedBy")

  // Dự án phụ — nâng cấp toàn diện: quan hệ ngược từ DailyReport (Báo cáo hằng ngày)
  dailyReports        DailyReport[] @relation("DailyReportAccount")
  createdDailyReports DailyReport[] @relation("DailyReportCreatedBy")
  updatedDailyReports DailyReport[] @relation("DailyReportUpdatedBy")

  // Dự án phụ — nâng cấp toàn diện: quan hệ ngược từ AttendanceRecord (Chấm công thủ công)
  attendanceRecords        AttendanceRecord[] @relation("AttendanceRecordAccount")
  createdAttendanceRecords AttendanceRecord[] @relation("AttendanceRecordCreatedBy")
  updatedAttendanceRecords AttendanceRecord[] @relation("AttendanceRecordUpdatedBy")

  @@map("accounts")
}

/// Mục 2.3, tài liệu 11 — Phiên đăng nhập (phục vụ đăng nhập nhiều thiết bị)
model Session {
  id           String    @id @default(uuid()) @db.Uuid
  accountId    String    @map("account_id") @db.Uuid
  deviceInfo   String?   @map("device_info") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  lastActiveAt DateTime  @default(now()) @map("last_active_at")
  revokedAt    DateTime? @map("revoked_at")

  account Account @relation(fields: [accountId], references: [id])

  @@map("sessions")
}

/// Mục 2.16, tài liệu 11 — Nhật ký truy cập/thao tác toàn hệ thống
model AuditLog {
  id           String          @id @default(uuid()) @db.Uuid
  accountId    String          @map("account_id") @db.Uuid
  actionType   AuditActionType @map("action_type")
  entityType   String          @map("entity_type") @db.VarChar(50)
  entityId     String?         @map("entity_id") @db.Uuid
  fieldChanged String?         @map("field_changed") @db.VarChar(100)
  oldValue     String?         @map("old_value")
  newValue     String?         @map("new_value")
  createdAt    DateTime        @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id])

  @@map("audit_logs")
}

// ── Phase 1 — Thu thập dữ liệu ứng viên ─────────────────────────────────

/// Khớp cột "category" của bảng status_catalog (Mục 2.7, tài liệu 11).
/// Chưa dùng đến ở Phase 1 (chỉ tồn tại để leads.*_status_id có FK hợp lệ),
/// nghiệp vụ đọc/ghi các trạng thái này sẽ do Phase 3/4 bổ sung.
enum StatusCategory {
  call_status
  call_result
  interview_status
  employment_status
  /// Dự án phụ — nâng cấp toàn diện: field/category kỹ thuật cũ, nay dùng
  /// cho cột "Kết quả" (chỉ 1 lựa chọn "Đã gửi CCCD") — xem seed.ts.
  zalo_status
  /// Dự án phụ — nâng cấp toàn diện: tình trạng kết bạn Zalo (thêm lại, tách
  /// riêng khỏi "Kết quả") — 3 lựa chọn cố định: chưa kết bạn / đã kết bạn /
  /// không có Zalo — xem seed.ts.
  zalo_friend_status

  @@map("status_category")
}

/// Dự án phụ — nâng cấp toàn diện: 3 màu đánh dấu cố định cho ô "Lịch sử
/// ghi chú/cuộc gọi" trên trang Chi tiết ứng viên (không phải StatusCatalog).
enum NoteColor {
  yellow
  green
  red

  @@map("note_color")
}

/// Khớp cột "assignment_method" của bảng leads (Mục 2.8, tài liệu 11).
/// Chưa dùng đến ở Phase 1 — do Phase 2 (thủ công) / Phase 6 (auto) ghi.
enum AssignmentMethod {
  manual
  auto

  @@map("assignment_method")
}

/// Trạng thái 1 lượt import Excel — bảng tự bổ sung, xem ghi chú đầu file.
enum ImportJobStatus {
  pending
  processing
  completed
  failed

  @@map("import_job_status")
}

/// Mục 2.6, tài liệu 11 — Danh mục nguồn kênh (Facebook/TikTok/Zalo/Khác)
model LeadSource {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(50)

  leads Lead[]

  @@map("lead_sources")
}

/// Mục 2.7, tài liệu 11 — Danh mục trạng thái chuẩn hóa (chưa dùng ở Phase 1)
model StatusCatalog {
  id        String         @id @default(uuid()) @db.Uuid
  category  StatusCategory
  code      String         @db.VarChar(50)
  name      String         @db.VarChar(100)
  sortOrder Int            @default(0) @map("sort_order") @db.SmallInt

  leadsByCallStatus              Lead[]                 @relation("LeadCallStatus")
  leadsByCallResult              Lead[]                 @relation("LeadCallResult")
  leadsByZaloStatus              Lead[]                 @relation("LeadZaloStatus")
  leadsByZaloFriendStatus        Lead[]                 @relation("LeadZaloFriendStatus")
  leadsByCurrentInterviewStatus  Lead[]                 @relation("LeadCurrentInterviewStatus")
  leadsByCurrentEmploymentStatus Lead[]                 @relation("LeadCurrentEmploymentStatus")
  notesByCallStatus              LeadNote[]             @relation("LeadNoteCallStatus")
  notesByCallResult              LeadNote[]             @relation("LeadNoteCallResult")
  notesByZaloFriendStatus        LeadNote[]             @relation("LeadNoteZaloFriendStatus")
  interviewsByStatus             InterviewAppointment[] @relation("InterviewAppointmentStatus")
  interviewsByEmploymentStatus   InterviewAppointment[] @relation("InterviewAppointmentEmploymentStatus")

  @@unique([category, code])
  @@map("status_catalog")
}

/// Mục 2.8, tài liệu 11 — Bảng trung tâm: thông tin & trạng thái ứng viên.
/// Xem ghi chú đầu file: đầy đủ cột theo tài liệu 11, nhưng Phase 1 chỉ có
/// API/logic cho phần tạo/sửa/xóa/tìm kiếm cơ bản — các cột còn lại luôn rỗng.
model Lead {
  id               String   @id @default(uuid()) @db.Uuid
  fullName         String   @map("full_name") @db.VarChar(150)
  phoneNumber      String   @map("phone_number") @db.VarChar(20)
  birthYear        Int?     @map("birth_year") @db.SmallInt
  address          String?  @db.VarChar(255)
  sourceId         String   @map("source_id") @db.Uuid
  mktNote          String?  @map("mkt_note")
  dataQualityScore Int?     @map("data_quality_score") @db.SmallInt
  uploadedById     String   @map("uploaded_by") @db.Uuid
  uploadedAt       DateTime @default(now()) @map("uploaded_at")

  // Phase 2 — chưa có logic ghi ở Phase 1, luôn NULL
  assignedToId     String?           @map("assigned_to") @db.Uuid
  assignedTeamId   String?           @map("assigned_team_id") @db.Uuid
  assignedAt       DateTime?         @map("assigned_at")
  assignmentMethod AssignmentMethod? @map("assignment_method")

  // Phase 3 — chưa có logic ghi ở Phase 1, luôn NULL
  callStatusId String? @map("call_status_id") @db.Uuid
  callResultId String? @map("call_result_id") @db.Uuid

  // Dự án phụ — nâng cấp toàn diện: cột "Kết quả" (chỉ "Đã gửi CCCD"), chọn tại trang Chi tiết ứng viên.
  zaloStatusId String? @map("zalo_status_id") @db.Uuid

  // Dự án phụ — nâng cấp toàn diện: tình trạng kết bạn Zalo (tách riêng khỏi
  // "Kết quả" ở trên), chọn tại trang Chi tiết ứng viên.
  zaloFriendStatusId String? @map("zalo_friend_status_id") @db.Uuid

  // Dự án phụ — nâng cấp toàn diện: màu đánh dấu ô "Lịch sử ghi chú/cuộc gọi"
  // trên trang Chi tiết ứng viên (không liên quan StatusCatalog — chỉ 3 màu cố định).
  noteColor NoteColor? @map("note_color")

  // Phase 4 — chưa có logic ghi ở Phase 1, luôn NULL
  currentInterviewStatusId  String? @map("current_interview_status_id") @db.Uuid
  currentEmploymentStatusId String? @map("current_employment_status_id") @db.Uuid
  currentPartnerCompanyName String? @map("current_partner_company_name") @db.VarChar(150)

  // Phase 5 — chưa có logic ghi ở Phase 1, luôn giá trị mặc định/NULL
  isHeld                  Boolean   @default(false) @map("is_held")
  heldById                String?   @map("held_by") @db.Uuid
  heldAt                  DateTime? @map("held_at")
  lastActivityAt          DateTime? @map("last_activity_at")
  enteredCarePoolAt       DateTime? @map("entered_care_pool_at")
  carePoolLockedById      String?   @map("care_pool_locked_by") @db.Uuid
  carePoolLockedAt        DateTime? @map("care_pool_locked_at")
  removedFromCarePoolById String?   @map("removed_from_care_pool_by") @db.Uuid
  removedFromCarePoolAt   DateTime? @map("removed_from_care_pool_at")

  // Phase 1
  isDuplicateFlagged Boolean   @default(false) @map("is_duplicate_flagged")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  deletedById        String?   @map("deleted_by") @db.Uuid

  source                  LeadSource             @relation(fields: [sourceId], references: [id])
  uploadedBy              Account                @relation("LeadUploadedBy", fields: [uploadedById], references: [id])
  assignedTo              Account?               @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  heldBy                  Account?               @relation("LeadHeldBy", fields: [heldById], references: [id])
  carePoolLockedBy        Account?               @relation("LeadCarePoolLockedBy", fields: [carePoolLockedById], references: [id])
  removedFromCarePoolBy   Account?               @relation("LeadRemovedFromCarePoolBy", fields: [removedFromCarePoolById], references: [id])
  deletedBy               Account?               @relation("LeadDeletedBy", fields: [deletedById], references: [id])
  callStatus              StatusCatalog?         @relation("LeadCallStatus", fields: [callStatusId], references: [id])
  callResult              StatusCatalog?         @relation("LeadCallResult", fields: [callResultId], references: [id])
  zaloStatus              StatusCatalog?         @relation("LeadZaloStatus", fields: [zaloStatusId], references: [id])
  zaloFriendStatus        StatusCatalog?         @relation("LeadZaloFriendStatus", fields: [zaloFriendStatusId], references: [id])
  currentInterviewStatus  StatusCatalog?         @relation("LeadCurrentInterviewStatus", fields: [currentInterviewStatusId], references: [id])
  currentEmploymentStatus StatusCatalog?         @relation("LeadCurrentEmploymentStatus", fields: [currentEmploymentStatusId], references: [id])
  notes                   LeadNote[]
  interviews              InterviewAppointment[]
  callbacks               CallbackSchedule[]
  notifications           Notification[]

  @@index([phoneNumber])
  @@index([uploadedAt])
  @@index([deletedAt])
  @@index([assignedToId])
  @@index([assignedTeamId])
  @@index([assignedTeamId, enteredCarePoolAt])
  @@index([isHeld, enteredCarePoolAt, lastActivityAt])
  @@map("leads")
}

/// Bảng tự bổ sung — theo dõi tiến độ 1 lượt import Excel (xem ghi chú đầu file)
model ImportJob {
  id             String          @id @default(uuid()) @db.Uuid
  uploadedById   String          @map("uploaded_by") @db.Uuid
  fileName       String?         @map("file_name") @db.VarChar(255)
  status         ImportJobStatus @default(pending)
  totalRows      Int?            @map("total_rows")
  successCount   Int             @default(0) @map("success_count")
  errorCount     Int             @default(0) @map("error_count")
  duplicateCount Int             @default(0) @map("duplicate_count")
  errors         String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  uploadedBy Account @relation(fields: [uploadedById], references: [id])

  @@map("import_jobs")
}

// ── Phase 3 — Pipeline cuộc gọi & Lịch sử ghi chú ────────────────────────

/// Mục 2.9, tài liệu 11 — Lịch sử ghi chú/cuộc gọi của từng lead. Xóa mềm
/// (is_deleted) để giữ lịch sử đầy đủ kể cả note đã xóa (Mục 10, tài liệu 09).
model LeadNote {
  id           String    @id @default(uuid()) @db.Uuid
  leadId       String    @map("lead_id") @db.Uuid
  createdById  String    @map("created_by") @db.Uuid
  content      String
  callStatusId String?   @map("call_status_id") @db.Uuid
  callResultId String?   @map("call_result_id") @db.Uuid
  // Dự án phụ — nâng cấp toàn diện: snapshot "Tình trạng Zalo" tại thời điểm
  // ghi note, cùng cơ chế với callStatusId/callResultId ở trên — hiện dưới
  // dạng "tag" phía trên note (Mục 2.9, docs/11).
  zaloFriendStatusId String?   @map("zalo_friend_status_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  isDeleted          Boolean   @default(false) @map("is_deleted")
  deletedById        String?   @map("deleted_by") @db.Uuid
  deletedAt          DateTime? @map("deleted_at")

  lead             Lead           @relation(fields: [leadId], references: [id])
  createdBy        Account        @relation("LeadNoteCreatedBy", fields: [createdById], references: [id])
  deletedBy        Account?       @relation("LeadNoteDeletedBy", fields: [deletedById], references: [id])
  callStatus       StatusCatalog? @relation("LeadNoteCallStatus", fields: [callStatusId], references: [id])
  callResult       StatusCatalog? @relation("LeadNoteCallResult", fields: [callResultId], references: [id])
  zaloFriendStatus StatusCatalog? @relation("LeadNoteZaloFriendStatus", fields: [zaloFriendStatusId], references: [id])

  @@index([leadId])
  @@index([leadId, createdAt])
  @@map("lead_notes")
}

// ── Phase 4 — Lịch phỏng vấn, lịch gọi lại & Calendar ────────────────────

/// Mục 2.10, tài liệu 11 — Lịch sử các lần hẹn phỏng vấn của 1 lead. Mỗi lần
/// bùng PV (no-show) và hẹn lại tạo 1 dòng mới với attempt_no tăng dần, giữ
/// nguyên toàn bộ lịch sử các lần hẹn trước đó.
model InterviewAppointment {
  id                 String   @id @default(uuid()) @db.Uuid
  leadId             String   @map("lead_id") @db.Uuid
  attemptNo          Int      @default(1) @map("attempt_no") @db.SmallInt
  partnerCompanyName String   @map("partner_company_name") @db.VarChar(150)
  scheduledAt        DateTime @map("scheduled_at")
  statusId           String   @map("status_id") @db.Uuid
  employmentStatusId String?  @map("employment_status_id") @db.Uuid
  employmentReason   String?  @map("employment_reason")
  createdById        String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  lead             Lead           @relation(fields: [leadId], references: [id])
  status           StatusCatalog  @relation("InterviewAppointmentStatus", fields: [statusId], references: [id])
  employmentStatus StatusCatalog? @relation("InterviewAppointmentEmploymentStatus", fields: [employmentStatusId], references: [id])
  createdBy        Account        @relation("InterviewAppointmentCreatedBy", fields: [createdById], references: [id])

  @@index([leadId])
  @@index([scheduledAt])
  @@map("interview_appointments")
}

/// Mục 2.11, tài liệu 11 — Lịch hẹn gọi lại của 1 lead.
model CallbackSchedule {
  id          String   @id @default(uuid()) @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  scheduledAt DateTime @map("scheduled_at")
  isCompleted Boolean  @default(false) @map("is_completed")
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  lead      Lead    @relation(fields: [leadId], references: [id])
  createdBy Account @relation("CallbackScheduleCreatedBy", fields: [createdById], references: [id])

  @@index([leadId])
  @@index([scheduledAt])
  @@map("callback_schedules")
}

// ── Phase 5 — Cột chăm sóc tự động (Care Pool) ───────────────────────────

/// Mục 2.15, tài liệu 11 — Tham số cấu hình hệ thống (vd ngưỡng thời gian
/// vào cột chăm sóc). Seed sẵn CARE_POOL_THRESHOLD_MINUTES="30" khi cài đặt.
model SystemConfig {
  id          String   @id @default(uuid()) @db.Uuid
  configKey   String   @unique @map("config_key") @db.VarChar(100)
  configValue String   @map("config_value") @db.VarChar(255)
  description String?  @db.VarChar(255)
  updatedById String   @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy Account @relation(fields: [updatedById], references: [id])

  @@map("system_configs")
}

/// Dự án phụ — nâng cấp toàn diện: độ rộng cột do Admin tùy chỉnh, áp dụng
/// chung cho MỌI tài khoản (không phải preference riêng từng người).
/// `tableKey` là 1 chuỗi tự do do từng trang tự đặt (vd "candidates_list",
/// "sale_performance") — không cần đổi schema/migration khi thêm bảng mới
/// sau này, chỉ cần trang đó gọi PUT với tableKey riêng. `columnWidths` lưu
/// dạng JSON string {"tên_cột": độ_rộng_px, ...} — validate ở service, không
/// ràng buộc cấu trúc cột cụ thể ở DB (mỗi trang tự định nghĩa danh sách cột).
model ColumnWidthConfig {
  id            String   @id @default(uuid()) @db.Uuid
  tableKey      String   @unique @map("table_key") @db.VarChar(100)
  columnWidths  String   @map("column_widths") @db.VarChar(2000)
  updatedById   String   @map("updated_by") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at")

  updatedBy Account @relation(fields: [updatedById], references: [id])

  @@map("column_width_configs")
}

// ── Phase 6 — Tự động phân chia lead (Round-robin) ───────────────────────

/// Mục 2.12, tài liệu 11 — Cấu hình tự động phân chia của 1 nhóm (tối đa 1
/// cấu hình/nhóm). `lastAssignedPosition` là con trỏ vị trí kế tiếp trong
/// vòng quay round-robin (chỉ số trong danh sách `members`, sắp theo order_index).
model DistributionRule {
  id                   String   @id @default(uuid()) @db.Uuid
  teamId               String   @unique @map("team_id") @db.Uuid
  isActive             Boolean  @default(false) @map("is_active")
  lastAssignedPosition Int      @default(0) @map("last_assigned_position") @db.SmallInt
  createdById          String   @map("created_by") @db.Uuid
  updatedAt            DateTime @updatedAt @map("updated_at")

  team      Team                 @relation(fields: [teamId], references: [id])
  createdBy Account              @relation(fields: [createdById], references: [id])
  members   DistributionMember[]

  @@map("auto_distribution_rules")
}

/// Mục 2.13, tài liệu 11 — Danh sách + thứ tự Sale tham gia vòng quay của 1 cấu hình.
model DistributionMember {
  id         String @id @default(uuid()) @db.Uuid
  ruleId     String @map("rule_id") @db.Uuid
  accountId  String @map("account_id") @db.Uuid
  orderIndex Int    @map("order_index") @db.SmallInt

  rule    DistributionRule @relation(fields: [ruleId], references: [id])
  account Account          @relation(fields: [accountId], references: [id])

  @@unique([ruleId, orderIndex])
  @@unique([ruleId, accountId])
  @@map("auto_distribution_members")
}

// ── Phase 8 — Thông báo Zalo ──────────────────────────────────────────────

// Khớp cột "type" của bảng notifications (Mục 2.14, tài liệu 11)
enum NotificationType {
  callback_reminder
  interview_reminder
  /// Dự án phụ — nâng cấp toàn diện: Admin soạn + gửi thủ công cho 1 nhóm/
  /// nhiều thành viên cụ thể (POST /notification) — dùng chung ô "content".
  admin_message
  /// Dự án phụ — nâng cấp toàn diện (ngoài phạm vi Design Freeze docs/09-13):
  /// cảnh báo tự động 1 Sale không có bản ghi nào trong "Danh sách đưa đón"
  /// (shuttle_records.sale) suốt 3 ngày liên tiếp — xem SaleReminderService.
  sale_no_shuttle_reminder

  @@map("notification_type")
}

// Khớp cột "channel" của bảng notifications (Mục 2.14, tài liệu 11) — hiện
// chỉ có 1 giá trị (kênh gửi duy nhất đã xác nhận, Mục 10.10 tài liệu 09).
enum NotificationChannel {
  zalo
  /// Dự án phụ — nâng cấp toàn diện: thông báo trong ứng dụng (chuông/toast),
  /// không gửi qua Zalo — dùng cho type=admin_message.
  in_app

  @@map("notification_channel")
}

// Khớp cột "status" của bảng notifications (Mục 2.14, tài liệu 11)
enum NotificationStatus {
  pending
  sent
  failed

  @@map("notification_status")
}

/// Mục 2.14, tài liệu 11 — Hàng đợi thông báo nhắc lịch qua Zalo, worker nền
/// quét theo (status, scheduled_at) để gửi đúng lúc, tránh gửi trùng/thất lạc.
model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  accountId   String              @map("account_id") @db.Uuid
  leadId      String?             @map("lead_id") @db.Uuid
  type        NotificationType
  channel     NotificationChannel @default(zalo)
  /// Dự án phụ — nâng cấp toàn diện: nội dung tự soạn khi type=admin_message,
  /// null với 2 loại nhắc lịch cũ (nội dung tự dựng ở tầng hiển thị như trước).
  content     String?
  /// Dự án phụ — nâng cấp toàn diện: Admin đã gửi (type=admin_message), null
  /// với 2 loại nhắc lịch cũ (hệ thống tự tạo, không có người gửi cụ thể).
  senderId    String?             @map("sender_id") @db.Uuid
  scheduledAt DateTime            @map("scheduled_at")
  sentAt      DateTime?           @map("sent_at")
  status      NotificationStatus  @default(pending)
  createdAt   DateTime            @default(now()) @map("created_at")

  account Account  @relation(fields: [accountId], references: [id])
  sender  Account? @relation("NotificationSender", fields: [senderId], references: [id])
  lead    Lead?    @relation(fields: [leadId], references: [id])

  @@index([status, scheduledAt])
  @@index([leadId, type])
  @@map("notifications")
}

// ── Phase 9 — Phân quyền chi tiết (khung, chưa seed danh sách quyền) ────

/// Mục 2.4, tài liệu 11 — Danh mục quyền có thể cấu hình. RỖNG theo đúng
/// cảnh báo của docs/14-roadmap.md (Phase 9) — chờ xác nhận danh sách quyền
/// cụ thể từ chủ doanh nghiệp trước khi seed.
model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique @db.VarChar(50)
  name        String  @db.VarChar(150)
  description String? @db.VarChar(255)

  accountGrants AccountPermission[]

  @@map("permissions")
}

/// Mục 2.5, tài liệu 11 — Quyền cụ thể đã cấu hình cho 1 tài khoản
/// (Quản lý/Leader). `is_granted` mặc định false — chỉ bật khi Admin tick.
model AccountPermission {
  id           String   @id @default(uuid()) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  isGranted    Boolean  @default(false) @map("is_granted")
  updatedById  String   @map("updated_by") @db.Uuid
  updatedAt    DateTime @updatedAt @map("updated_at")

  account    Account    @relation("AccountPermissionAccount", fields: [accountId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  updatedBy  Account    @relation("AccountPermissionUpdatedBy", fields: [updatedById], references: [id])

  @@unique([accountId, permissionId])
  @@map("account_permissions")
}

// ── Dự án phụ — nâng cấp toàn diện: Danh sách đưa đón ────────────────────

/// Danh sách đưa đón lao động — nhập tay ĐỘC LẬP, thay thế Google Sheet đang
/// dùng. KHÔNG liên kết với Lead/ứng viên hay bất kỳ module nghiệp vụ nào
/// khác (yêu cầu trực tiếp người dùng) — mọi trường (kể cả "Sale"/"Nhà thầu")
/// đều là text tự do, không phải khóa ngoại. Mọi vai trò đã đăng nhập đều
/// được thêm/sửa/xóa tự do (không giới hạn theo nhóm/người phụ trách).
model ShuttleRecord {
  id            String   @id @default(uuid()) @db.Uuid
  date          DateTime @db.Date
  fullName      String   @map("full_name") @db.VarChar(150)
  phoneNumber   String   @map("phone_number") @db.VarChar(20)
  company       String?  @db.VarChar(150)
  area          String?  @db.VarChar(150)
  type          String?  @db.VarChar(100)
  sale          String?  @db.VarChar(150)
  driver        String?  @map("driver") @db.VarChar(150)
  /// Lưu dạng chuỗi "HH:mm" — chỉ là giờ hẹn PV, tách biệt khỏi cột "date".
  interviewTime String?  @map("interview_time") @db.VarChar(5)
  contractor    String?  @db.VarChar(150)
  /// "Tình trạng đón" (Đã đón/Chưa đón được/Hẹn lại) — tên cột DB giữ
  /// nguyên "status" (không đổi để tránh thêm 1 lần migrate) dù giao diện
  /// đã tách riêng khỏi "Kết quả PV" (interviewResult, xem bên dưới) — yêu
  /// cầu trực tiếp người dùng, tách 1 cột "Trạng thái" cũ thành 2 cột.
  status        String?  @db.VarChar(50)
  /// Dự án phụ — nâng cấp toàn diện: "Kết quả PV" (Đỗ phỏng vấn/Trượt phỏng
  /// vấn) — tách riêng khỏi "Tình trạng đón" ở trên.
  interviewResult String? @map("interview_result") @db.VarChar(50)
  note          String?
  createdById   String   @map("created_by") @db.Uuid
  updatedById   String   @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdBy Account @relation("ShuttleRecordCreatedBy", fields: [createdById], references: [id])
  updatedBy Account @relation("ShuttleRecordUpdatedBy", fields: [updatedById], references: [id])

  @@index([date])
  @@index([status])
  @@index([interviewResult])
  @@map("shuttle_records")
}

/// Dự án phụ — nâng cấp toàn diện: danh sách gợi ý CÓ LƯU LẠI (khác cách cũ
/// tự suy ra từ giá trị distinct trong shuttle_records) cho 7 trường "chọn"
/// của Danh sách đưa đón (Công ty/Khu vực/Loại hình/Sale/Nhân viên đưa đón/
/// Nhà thầu/Trạng thái) — cần bảng riêng vì yêu cầu trực tiếp người dùng:
/// xóa được 1 giá trị cũ khỏi danh sách gợi ý (không đụng dữ liệu các dòng
/// đã nhập), và chọn màu nền khi thêm giá trị mới — cả 2 việc này không thể
/// làm được nếu danh sách chỉ suy ra từ dữ liệu sẵn có. `colorKey` tham chiếu
/// 1 trong các màu cố định ở SHUTTLE_OPTION_COLORS (frontend) — null = màu
/// mặc định (xám).
model ShuttleOption {
  id        String   @id @default(uuid()) @db.Uuid
  field     String   @db.VarChar(20)
  value     String   @db.VarChar(150)
  colorKey  String?  @map("color_key") @db.VarChar(20)
  /// Dự án phụ — nâng cấp toàn diện (ngoài phạm vi Design Freeze docs/09-13):
  /// màu CHỮ riêng, độc lập với colorKey (màu nền) — yêu cầu trực tiếp người
  /// dùng: "ngoài cho phép đổi màu nền chữ thì cho phép đổi màu chữ nữa".
  /// null = dùng màu chữ tương phản tự động theo colorKey (hành vi cũ).
  textColorKey String? @map("text_color_key") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([field, value])
  @@index([field])
  @@map("shuttle_options")
}

/// Dự án phụ — nâng cấp toàn diện (2026-07-14, ngoài phạm vi Design Freeze
/// docs/09-13 — module hoàn toàn mới, yêu cầu trực tiếp người dùng): 1 dòng
/// báo cáo hằng ngày của 1 Sale. `date` luôn là NGÀY HIỆN TẠI theo giờ Việt
/// Nam tại thời điểm tạo (không cho chọn ngày khác — "báo cáo hằng ngày"),
/// sửa được CHỈ trong đúng ngày đó (xem daily-reports.service.ts). `teamId`
/// LƯU SNAPSHOT nhóm tại thời điểm báo cáo — cùng nguyên tắc denormalize đã
/// có sẵn với Lead.assignedTeamId (không phát minh quy ước mới), để lịch sử
/// báo cáo không đổi theo nếu Sale sau này chuyển nhóm. "Data mới" KHÔNG lưu
/// ở đây — luôn tính trực tiếp từ Lead.uploadedAt (đúng field "ngày lên số"
/// Dashboard/Báo cáo đang dùng làm chuẩn) tại thời điểm đọc, không cho nhập
/// tay (yêu cầu trực tiếp người dùng).
model DailyReport {
  id                 String   @id @default(uuid()) @db.Uuid
  date               DateTime @db.Date
  accountId          String   @map("account_id") @db.Uuid
  teamId             String?  @map("team_id") @db.Uuid
  calls              Int      @default(0)
  oldData            Int      @default(0) @map("old_data")
  noAnswer           Int      @default(0) @map("no_answer")
  interested         Int      @default(0)
  interviewScheduled Int      @default(0) @map("interview_scheduled")
  interviewPassed    Int      @default(0) @map("interview_passed")
  employed           Int      @default(0)
  createdById        String   @map("created_by") @db.Uuid
  updatedById        String   @map("updated_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  account   Account  @relation("DailyReportAccount", fields: [accountId], references: [id])
  team      Team?    @relation(fields: [teamId], references: [id])
  createdBy Account  @relation("DailyReportCreatedBy", fields: [createdById], references: [id])
  updatedBy Account  @relation("DailyReportUpdatedBy", fields: [updatedById], references: [id])

  /// "Mỗi nhân viên chỉ có 1 báo cáo cho mỗi ngày" — yêu cầu trực tiếp người dùng.
  @@unique([accountId, date])
  @@index([date])
  @@index([teamId])
  @@map("daily_reports")
}

/// Dự án phụ — nâng cấp toàn diện (2026-07-14, ngoài phạm vi Design Freeze
/// docs/09-13 — module hoàn toàn mới, yêu cầu trực tiếp người dùng): "Chấm
/// công thủ công". 1 bản ghi / (nhân viên, ngày thực tế) — "ô trống = chưa
/// chấm" thể hiện bằng KHÔNG có bản ghi (không dùng 1 giá trị enum riêng cho
/// "trống"), xóa trạng thái = xóa hẳn row (xem attendance.service.ts).
/// `note` phục vụ "đi muộn/về sớm... kèm ghi chú nếu cần" — gộp chung vào 1
/// field ghi chú tự do đi kèm MỌI trạng thái, không tách thành trạng thái
/// riêng (yêu cầu người dùng đã cho phép giản lược thao tác nâng cao ở Mục 4
/// nếu làm phức tạp quá).
model AttendanceRecord {
  id          String           @id @default(uuid()) @db.Uuid
  date        DateTime         @db.Date
  accountId   String           @map("account_id") @db.Uuid
  status      AttendanceStatus
  note        String?          @db.VarChar(255)
  createdById String           @map("created_by") @db.Uuid
  updatedById String           @map("updated_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  account   Account @relation("AttendanceRecordAccount", fields: [accountId], references: [id])
  createdBy Account @relation("AttendanceRecordCreatedBy", fields: [createdById], references: [id])
  updatedBy Account @relation("AttendanceRecordUpdatedBy", fields: [updatedById], references: [id])

  /// "Mỗi nhân viên, mỗi ngày chỉ có một bản ghi chấm công" — yêu cầu trực tiếp người dùng.
  @@unique([accountId, date])
  @@index([date])
  @@index([accountId])
  @@map("attendance_records")
}
