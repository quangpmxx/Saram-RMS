# Sao chép file này thành ".env" rồi chỉnh lại nếu cần — xem README.md ở
# thư mục gốc dự án để biết hướng dẫn từng bước.

# --- Database ---
# Mặc định khớp với docker-compose.yml ở thư mục gốc (POSTGRES_USER/PASSWORD/DB = saram).
# Nếu dùng "npx prisma dev" thay vì Docker, hãy thay giá trị này bằng URL mà
# lệnh đó in ra (cổng sẽ khác mỗi lần khởi tạo).
DATABASE_URL="postgresql://saram:saram@localhost:5432/saram_rms?schema=public"

# --- Server ---
PORT=3001
NODE_ENV=development
# Origin của frontend Next.js — phải khớp chính xác để CORS + cookie hoạt động.
CORS_ORIGIN="http://localhost:3000"

# --- Auth ---
# Đổi giá trị này khi triển khai thật — đây chỉ là giá trị mẫu cho môi trường dev.
JWT_SECRET="dev-only-secret-change-me-in-production-32chars-min"
JWT_EXPIRES_IN="8h"

# Mật khẩu mặc định khi Admin tạo tài khoản mới hoặc reset mật khẩu
# (Mục 8, docs/09-business-specification.md).
DEFAULT_PASSWORD="123456"

# Tên đăng nhập của tài khoản Admin đầu tiên, dùng bởi `npm run seed`.
SEED_ADMIN_USERNAME="admin"
